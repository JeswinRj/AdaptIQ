# ---- ADAPT-IQ configuration (copy to .env and edit) ----

# Data source: "csv" (default, works out of the box with the synthetic
# dataset) or "gsheet" (requires the Google credentials below).
DATA_SOURCE=csv
# CSV_PATH=data/synthetic_responses.csv

# --- Google Sheets mode (only when DATA_SOURCE=gsheet) ---
# GOOGLE_CREDENTIALS_FILE=/absolute/path/to/service_account.json
# GSHEET_NAME=ADAPT-IQ Responses
# GSHEET_WORKSHEET=Form Responses 1

# --- AI enhancement (optional; app is fully functional without) ---
# Pick ONE primary provider:
#   gemini      -> https://aistudio.google.com/apikey   free tier, no card
#                  (auto-retries on flash-lite when rate-limited)
#   groq        -> https://console.groq.com/keys        free tier, fast, high caps
#   openrouter  -> https://openrouter.ai/keys           ":free" models incl. DeepSeek
#   mistral     -> https://console.mistral.ai           free experiment tier
#   cerebras    -> https://cloud.cerebras.ai            free tier, very fast
#   deepseek    -> https://platform.deepseek.com        cheap but NOT free
#   ollama      -> https://ollama.com                   local, free forever, no key
# AI_PROVIDER=gemini
# AI_API_KEY=your-key-here
# AI_MODEL=            # empty = sensible default per provider

# Optional second provider tried automatically whenever the primary fails
# (rate limits, outages). Example: Gemini primary + Groq backup = no hiccups.
# AI_FALLBACK_PROVIDER=groq
# AI_FALLBACK_KEY=your-groq-key
# OLLAMA_HOST=http://localhost:11434

# Live resource fetching from Wikipedia (keyless, free). "0" forces offline.
LIVE_RESOURCES=1

# FLASK_SECRET_KEY=change-me
